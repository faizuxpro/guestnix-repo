# ==============================================
# Guestnix Environment Variables
# Copy this to .env.local and fill in your values
# ==============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=guidebook-assets
# Bucket where snapshot JSON for published guidebooks lives. Auto-created
# on first Publish. Optional — defaults to "guidebook-publications".
SUPABASE_PUBLICATIONS_BUCKET=guidebook-publications

# Postgres connection (Drizzle ORM — required for all DB queries)
# Get this from Supabase → Project Settings → Database → Connection string → URI
# Use the **Session pooler** (port 5432) for Drizzle (NOT the transaction pooler on 6543).
# Format: postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
# The DB password is the one you set when creating the project — NOT the service role key.
DATABASE_URL=postgresql://postgres:your_db_password@db.your-project.supabase.co:5432/postgres

# Strong secret used to sign guest Store request access links.
# Use a long random value in production, e.g. `openssl rand -base64 48`.
STORE_REQUEST_TOKEN_SECRET=your_long_random_store_request_secret

# AI (provider-agnostic chat layer)
# Point at any OpenAI-compatible endpoint: OpenAI, Groq, Together, Fireworks,
# DeepInfra, OpenRouter, Ollama, vLLM. Most providers only need these 3 values.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_api_key
AI_MODEL=gpt-4o-mini
AI_WIRE_API=auto
AI_FALLBACK_MODEL=
#
# Groq example:
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=your_groq_api_key
# AI_MODEL=llama-3.1-8b-instant
# AI_WIRE_API=auto

# Legacy (kept for future direct-SDK features; unused by chat):
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key

# Stripe (future — billing currently runs through Gumroad, see below)
STRIPE_SECRET_KEY=your_stripe_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_pub
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# Billing (provider-agnostic — Gumroad for the launch)
# ===================================================
# Select the active billing provider. 'gumroad' for now; switch to 'stripe'
# later without changing subscription/entitlement logic.
BILLING_PROVIDER=gumroad
# Gumroad creator subdomain: the <name> in https://<name>.gumroad.com
GUMROAD_CREATOR_SUBDOMAIN=
# Optional shared secret. If set, configure the Gumroad Ping URL (in the
# product's settings) as:
#   https://<your-app>/api/billing/gumroad/webhook?key=<this value>
# The key never appears in the user-facing checkout URL.
GUMROAD_WEBHOOK_SECRET=
# Gumroad product permalinks — the code in gumroad.com/l/<permalink> — for each
# plan, monthly (_M) and annual (_Y). Create one membership product per row.
GUMROAD_PRODUCT_SOLO_M=
GUMROAD_PRODUCT_SOLO_Y=
GUMROAD_PRODUCT_PLUS_M=
GUMROAD_PRODUCT_PLUS_Y=
GUMROAD_PRODUCT_PRO_M=
GUMROAD_PRODUCT_PRO_Y=
GUMROAD_PRODUCT_SCALE_M=
GUMROAD_PRODUCT_SCALE_Y=

# Email (transactional)
EMAIL_PROVIDER=mailjet
EMAIL_FROM="Guestnix <hello@yourdomain.com>"

# Mailjet
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM_EMAIL="Guestnix <hello@yourdomain.com>"

# Brevo
BREVO_API_KEY=your_brevo_key
BREVO_FROM_EMAIL="Guestnix <hello@yourdomain.com>"

# Resend
RESEND_API_KEY=your_resend_key
RESEND_FROM_EMAIL="Guestnix <hello@yourdomain.com>"

# Redis (Upstash) - for rate limiting
UPSTASH_REDIS_REST_URL=your_redis_url
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Guestnix
NEXT_PUBLIC_BETA_ENABLED=true
NEXT_PUBLIC_BETA_TRIAL_EXTENSION_FORM_URL=https://forms.gle/replace-with-your-beta-feedback-form
# Comma-separated Supabase user IDs that can access /dashboard/admin/activity.
# You can also set auth.users.app_metadata.role = "admin" in Supabase.
PLATFORM_ADMIN_USER_IDS=
# The hostname where this app is served. The middleware uses this to
# distinguish canonical Guestnix traffic from custom-domain requests.
# Don't include protocol or trailing slash. In dev, leave unset and
# requests on localhost / *.herokuapp.com are treated as canonical.
NEXT_PUBLIC_CANONICAL_HOST=guestnix.com

# Custom domains (Heroku provider)
# ================================
# Required to let hosts attach their own domains (guide.acmehouse.com /
# acmehouse.com) to their guidebooks. The middleware routes incoming
# requests on those hosts to the matching guidebook snapshot.
#
# - HEROKU_API_KEY:  Heroku API key with access to the production app.
# - HEROKU_APP_NAME: Heroku app name that serves Guestnix.
CUSTOM_DOMAIN_PROVIDER=heroku
HEROKU_API_KEY=
HEROKU_APP_NAME=guestnix

# Production visibility and analytics
# ===================================
# Sentry: errors, replay-on-error, and user feedback. Auth token is only needed
# for source map upload in CI/provider builds; never expose it client-side.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# New Relic: server APM, traces, logs/runtime visibility.
NEW_RELIC_APP_NAME=Guestnix
NEW_RELIC_LICENSE_KEY=

# Honeybadger: uptime checks are configured in the Honeybadger dashboard.
# Keep this for future check-ins if scheduled jobs are added.
HONEYBADGER_API_KEY=

# Google Analytics 4: marketing/auth page analytics only.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Set true in regions/deployments where GA4/PostHog must wait for explicit consent.
NEXT_PUBLIC_ANALYTICS_CONSENT_REQUIRED=false

# Google Search Console: optional meta verification. Prefer DNS TXT when possible.
GOOGLE_SITE_VERIFICATION=

# PostHog: product analytics only. Leave replay disabled at launch.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# GitHub Pro/CodeScene setup notes:
# - Enable Dependabot alerts, secret scanning, push protection, and code scanning in GitHub.
# - Connect CodeScene Student to the private GitHub repository from the CodeScene dashboard.
