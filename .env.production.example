# Production environment variables for Guestnix
# Copy this to .env.production and fill in your production values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-production-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key
SUPABASE_STORAGE_BUCKET=guidebook-assets
SUPABASE_PUBLICATIONS_BUCKET=guidebook-publications
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
STORE_REQUEST_TOKEN_SECRET=replace_with_long_random_secret

# Production app URL
NEXT_PUBLIC_APP_URL=https://guestnix.com
NEXT_PUBLIC_CANONICAL_HOST=guestnix.com
NEXT_PUBLIC_BETA_ENABLED=true
NEXT_PUBLIC_BETA_TRIAL_EXTENSION_FORM_URL=https://forms.gle/replace-with-your-beta-feedback-form
PLATFORM_ADMIN_USER_IDS=

# Transactional email
EMAIL_PROVIDER=mailjet
EMAIL_FROM="Guestnix <hello@guestnix.com>"
MAILJET_API_KEY=your_production_mailjet_api_key
MAILJET_SECRET_KEY=your_production_mailjet_secret_key
MAILJET_FROM_EMAIL="Guestnix <hello@guestnix.com>"
BREVO_API_KEY=your_production_brevo_key
BREVO_FROM_EMAIL="Guestnix <hello@guestnix.com>"
RESEND_API_KEY=
RESEND_FROM_EMAIL="Guestnix <hello@guestnix.com>"

# AI provider
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_production_api_key
AI_MODEL=gpt-4o-mini
AI_WIRE_API=auto
AI_FALLBACK_MODEL=

# Billing
BILLING_PROVIDER=gumroad
GUMROAD_CREATOR_SUBDOMAIN=
GUMROAD_WEBHOOK_SECRET=

# Heroku custom domains for guidebooks
CUSTOM_DOMAIN_PROVIDER=heroku
HEROKU_API_KEY=
HEROKU_APP_NAME=guestnix

# Production visibility and analytics
# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# New Relic
NEW_RELIC_APP_NAME=Guestnix
NEW_RELIC_LICENSE_KEY=

# Honeybadger server/client error reporting
HONEYBADGER_API_KEY=
NEXT_PUBLIC_HONEYBADGER_API_KEY=
NEXT_PUBLIC_HONEYBADGER_ASSETS_URL=https://guestnix.com
NEXT_PUBLIC_HONEYBADGER_REVISION=

# Google Analytics 4 and Search Console
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ANALYTICS_CONSENT_REQUIRED=false
GOOGLE_SITE_VERIFICATION=

# PostHog product analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Manual production setup notes:
# - Configure Honeybadger uptime checks in the Honeybadger dashboard if needed.
# - Enable GitHub Pro security settings in the repository Security settings.
# - Connect CodeScene Student to the private GitHub repository.
